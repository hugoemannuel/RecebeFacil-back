# Database
DATABASE_URL="postgresql://root:rootpassword@localhost:5432/recebefacil?schema=public"

# Server Configuration
PORT=3001
NODE_ENV=development

# Security & Auth
JWT_SECRET=your_jwt_secret_key_here
ANON_SALT=your_random_anon_salt_here

# Integrations - Asaas (Payments)
ASAAS_API_KEY=your_asaas_api_key_here
ASAAS_WEBHOOK_SECRET=your_asaas_webhook_token_here

# Integrations - Z-API (WhatsApp) - Optional / Per Instance in DB
# ZAPI_API_URL=https://api.z-api.io/instances/YOUR_INSTANCE/token/YOUR_TOKEN
# ZAPI_API_TOKEN=your_zapi_api_token_here

# CORS Configuration
FRONTEND_URL=http://localhost:3000
