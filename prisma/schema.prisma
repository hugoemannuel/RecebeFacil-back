// Este é o schema Prisma do RecebeFácil
// Baseado na documentação de Backend e Security Guidelines
// REGRA: A tabela User contém APENAS dados de identidade/auth.
// Dados de negócio, PIX, WhatsApp e integrações ficam em tabelas separadas.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum PlanType {
  FREE
  STARTER
  PRO
  UNLIMITED
}

enum SubStatus {
  ACTIVE
  INACTIVE
  PAUSED
  CANCELED
  OVERDUE
  PENDING
}

enum SubPeriod {
  MONTHLY
  YEARLY
}

enum SubModule {
  HOME
  CHARGES
  CLIENTS
  REPORTS
  EXCEL_IMPORT
}

enum ChargeStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
}

enum TriggerType {
  MANUAL
  AUTO_REMINDER_BEFORE
  AUTO_REMINDER_DUE
  AUTO_REMINDER_OVERDUE
}

enum Frequency {
  WEEKLY
  MONTHLY
  YEARLY
}

enum PixKeyType {
  CPF
  CNPJ
  PHONE
  EMAIL
  EVP
}

enum MessageTrigger {
  MANUAL
  BEFORE_DUE
  ON_DUE
  OVERDUE
}

// ==========================================
// IDENTIDADE & AUTENTICAÇÃO
// User contém APENAS dados de auth. Regra de Ouro do projeto.
// ==========================================

model User {
  id            String  @id @default(uuid())
  phone         String  @unique // DDI+DDD+Num (Ex: 5511999999999)
  name          String
  email         String? @unique
  password_hash String?
  is_registered Boolean @default(false) // false = Shadow User

  avatar_url    String?

  // Relacionamentos de cobrança
  charges_as_creditor   Charge[]                @relation("CreditorCharges")
  charges_as_debtor     Charge[]                @relation("DebtorCharges")
  recurring_as_creditor RecurringCharge[]       @relation("CreditorRecurring")
  recurring_as_debtor   RecurringChargeDebtor[] @relation("DebtorRecurringRecord")

  // Clientes vinculados
  clients_as_creditor Client[] @relation("CreditorClients")
  clients_as_debtor   Client[] @relation("DebtorClients")

  // Perfis e configurações (tabelas separadas — segurança por contenção)
  creditor_profile  CreditorProfile?
  subscription      Subscription?
  integration_config IntegrationConfig?
  audit_logs        AuditLog[]          @relation("UserAuditLogs")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// PERFIL DO LOJISTA (dados de negócio)
// Separado do User para não vazar dados comerciais junto com auth.
// ==========================================

model CreditorProfile {
  id              String  @id @default(uuid())
  user_id         String  @unique
  user            User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Dados comerciais
  business_name   String?              // Nome da empresa/profissional
  document        String?              // CPF ou CNPJ (opcional no cadastro)
  logo_url        String?              // URL da logo da empresa

  // Configurações PIX
  pix_key         String?              // Chave PIX
  pix_key_type    PixKeyType?          // Tipo da chave
  pix_merchant_name String?            @db.VarChar(25) // Máx 25 chars (protocolo PIX)
  pix_qr_code_url   String?            // URL pública do QR Code gerado

  // Templates de mensagem (relação 1:N)
  message_templates MessageTemplate[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// TEMPLATES DE MENSAGEM WHATSAPP
// Separado para permitir múltiplos templates por lojista.
// ==========================================

model MessageTemplate {
  id                  String         @id @default(uuid())
  creditor_profile_id String
  creditor_profile    CreditorProfile @relation(fields: [creditor_profile_id], references: [id], onDelete: Cascade)

  name     String        // Ex: "Cobrança Inicial", "Lembrete Amigável"
  trigger  MessageTrigger
  body     String        // Corpo da mensagem com variáveis {{nome}}, {{valor}}, etc.
  is_default Boolean     @default(false) // Template padrão para o gatilho

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// CONFIGURAÇÕES DE INTEGRAÇÕES DE TERCEIROS
// Credenciais de APIs externas nunca ficam no User.
// ==========================================

model IntegrationConfig {
  id      String @id @default(uuid())
  user_id String @unique
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Z-API (WhatsApp)
  zapi_instance_id    String? // ID da instância Z-API do lojista (futuro: número próprio)
  zapi_instance_token String? // Token da instância Z-API
  allows_automation   Boolean @default(true) // Opt-out de automações (se devedor enviou PARAR)

  // Asaas (Gateway de pagamento para ASSINATURA do lojista)
  asaas_customer_id   String? // ID do lojista como Customer no Asaas

  // Futuro: Asaas Connect (split de pagamentos)
  asaas_wallet_id     String? // Sub-conta do lojista no Asaas Connect
  asaas_account_key   String? // Chave de acesso da sub-conta (criptografar em repouso)
  
  // Auditoria de Split
  split_terms_accepted_at DateTime?
  split_terms_version     String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// ASSINATURA & PLANO
// ==========================================

model Subscription {
  id                   String    @id @default(uuid())
  user_id              String    @unique
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan_type            PlanType
  status               SubStatus @default(PENDING)
  period               SubPeriod @default(MONTHLY)
  current_period_start DateTime?
  current_period_end   DateTime?
  
  // Integração Asaas
  asaas_id             String?   @unique // ID da assinatura no Asaas
  asaas_payment_id     String?   // ID da última cobrança no Asaas
  last_payment_at      DateTime?

  // Grace period de falha de pagamento (4 dias antes de cancelar)
  payment_failed_at      DateTime?
  payment_failure_reason String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

// ==========================================
// COBRANÇAS
// ==========================================

model Charge {
  id             String       @id @default(uuid())
  creditor_id    String
  debtor_id      String
  amount         Int          // Em centavos (Ex: R$ 50,00 = 5000)
  description    String
  due_date       DateTime
  status         ChargeStatus @default(PENDING)
  payment_date   DateTime?
  custom_message String?      // Mensagem customizada para este envio específico

  // Flags futuras para intermediação de pagamento (split Asaas)
  is_intermediated Boolean  @default(false)
  platform_fee_pct Decimal? // % de taxa (padrão: 1.00)
  asaas_payment_id String?  // ID da cobrança no Asaas (quando intermediada)

  creditor User             @relation("CreditorCharges", fields: [creditor_id], references: [id], onDelete: Cascade)
  debtor   User             @relation("DebtorCharges", fields: [debtor_id], references: [id], onDelete: Cascade)
  messages MessageHistory[]

  recurring_charge_id String?
  recurring_charge    RecurringCharge? @relation(fields: [recurring_charge_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model MessageHistory {
  id           String      @id @default(uuid())
  charge_id    String
  charge       Charge      @relation(fields: [charge_id], references: [id], onDelete: Cascade)
  trigger_type TriggerType
  sent_at      DateTime    @default(now())
  status       String      // SENT, FAILED
  zapi_message_id String?  // ID retornado pela Z-API para rastreamento
  error_details   String?  // Detalhes do erro em caso de FAILED (nunca expor na API)
}

// ==========================================
// COBRANÇAS RECORRENTES
// ==========================================

model RecurringCharge {
  id                   String    @id @default(uuid())
  creditor_id          String
  amount               Int
  description          String
  frequency            Frequency
  next_generation_date DateTime
  active               Boolean   @default(true)
  custom_message       String?

  creditor User                    @relation("CreditorRecurring", fields: [creditor_id], references: [id], onDelete: Cascade)
  debtors  RecurringChargeDebtor[]
  charges  Charge[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model RecurringChargeDebtor {
  id                  String @id @default(uuid())
  recurring_charge_id String
  debtor_id           String

  recurring_charge RecurringCharge @relation(fields: [recurring_charge_id], references: [id], onDelete: Cascade)
  debtor           User            @relation("DebtorRecurringRecord", fields: [debtor_id], references: [id], onDelete: Cascade)
}

// ==========================================
// CLIENTES
// Vínculo entre credor e devedor com metadados por relação.
// ==========================================

model Client {
  id          String   @id @default(uuid())
  creditor_id String
  user_id     String
  notes       String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  creditor User @relation("CreditorClients", fields: [creditor_id], references: [id], onDelete: Cascade)
  user     User @relation("DebtorClients",   fields: [user_id],     references: [id], onDelete: Cascade)

  @@unique([creditor_id, user_id])
}

// ==========================================
// DEMO AO VIVO
// Controle de uma tentativa por IP (hash SHA-256 — fora do escopo LGPD).
// ==========================================

model DemoAttempt {
  id        String   @id @default(uuid())
  ipHash    String   @unique
  createdAt DateTime @default(now())
}

// ==========================================
// AUDITORIA
// ==========================================

model AuditLog {
  id         String  @id @default(uuid())
  user_id    String?
  action     String  // Ex: CHARGE_SENT, SUBSCRIPTION_ACTIVATED, PIX_CONFIG_UPDATED
  entity     String  // Nome da tabela afetada
  entity_id  String  // ID do registro afetado
  details    Json?   // Dados adicionais (NUNCA incluir senhas, tokens, cartões)
  ip_address String?

  user User? @relation("UserAuditLogs", fields: [user_id], references: [id], onDelete: SetNull)

  created_at DateTime @default(now())
}

// ==========================================
// TERMOS E TAXAS DE SPLIT (DINÂMICO)
// ==========================================
model SplitTerm {
  id              String   @id @default(uuid())
  version         String   @unique
  content         String   @db.Text
  is_active       Boolean  @default(true)
  
  platform_fee_pct Decimal @default(1.0)
  asaas_pix_fee    String  @default("R$ 0,99")
  asaas_boleto_fee String  @default("R$ 1,99")
  asaas_card_fee   String  @default("2.99% + R$ 0,49")

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt
}
